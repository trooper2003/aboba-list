{% extends 'base.html.twig' %}

{% block title %} Абоба {{ id }} {% endblock %}

{% block body %}
    <div class="flex flex-col items-center min-h-screen px-4">
        <h1 class="text-orange-400 text-6xl pb-10 pt-3 font-bold">Абоба номер {{ id }}</h1>

        <div class="border-4 border-orange-500 rounded-3xl p-5 bg-purple-800/30 shadow-2xl w-full max-w-2xl">
            <table class="text-3xl text-yellow-300 border-separate border-spacing-x-6 border-spacing-y-4 table-fixed">
                <tbody>
                <tr class="border-b border-orange-500/30">
                    <th class="text-orange-400 text-right font-black uppercase tracking-wider w-1/2">Имя:</th>
                    <td class="font-light">{{ aboba.name }}</td>
                </tr>
                <tr>
                    <th class="text-orange-400 text-right font-black uppercase tracking-wider w-1/2">Возраст:</th>
                    <td class="font-light">{{ aboba.age }}</td>
                </tr>
                <tr>
                    <th class="text-orange-400 text-right font-black uppercase tracking-wider w-1/2">Семейное положение:</th>
                    <td class="font-light">
                        <div class="flex items-center gap-2">
                            <span>{{ aboba.MarriedStatusString }}</span>
                            <img class="w-auto h-21 object-contain border-2 p-1 border-orange-400 rounded-xl" src="{{ asset( aboba.MarriedStatusFilename ) }}">
                        </div>
                    </td>
                </tr>
                <tr>
                    <th class="text-orange-400 text-right font-black uppercase tracking-wider w-1/2">Абоба создан:</th>
                    <td class="font-light">{{ aboba.createdAt|ago(locale='ru') }}</td>
                </tr>
                </tbody>
            </table>
        </div>
        <a class="flex hover:bg-purple-900 items-center border-3 border-orange-500 rounded-3xl p-3 m-4 bg-purple-800/30 shadow-2xl transition-all duration-300 hover:scale-105 gap-3"
           href="{{ path('app_home_page') }}">

            <img src="{{ asset('images/back_arrow.png') }}"
            class="w-12 h-12">
            <span class="text-yellow-300 text-4xl">Назад</span>
        </a>
    </div>
{% endblock %}
