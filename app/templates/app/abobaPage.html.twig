{% extends 'base.html.twig' %}

{% macro info_row(label, value, extra_tr_classes = '') %}
    <tr{% if extra_tr_classes %} class="{{ extra_tr_classes }}"{% endif %}>
        <th class="text-orange-400 text-right font-black uppercase tracking-wider w-1/2">{{ label }}:</th>
        <td class="font-light">{{ value|raw }}</td>
    </tr>
{% endmacro %}

{% block title %} Абоба {{ id }} {% endblock %}

{% block body %}
    {% import _self as macros %}
    {% set container_classes = 'border-orange-500 rounded-3xl bg-purple-800/30 shadow-2xl' %}

    <div class="flex flex-col items-center min-h-screen px-4">
        <h1 class="text-orange-400 text-6xl pb-10 pt-3 font-bold">Абоба номер {{ id }}</h1>

        <div class="border-4 p-5 w-full max-w-2xl {{ container_classes }}">
            <table class="text-3xl text-yellow-300 border-separate border-spacing-x-6 border-spacing-y-4 table-fixed">
                <tbody>
                    {{ macros.info_row('Имя', aboba.name, 'border-b border-orange-500/30') }}
                    {{ macros.info_row('Возраст', aboba.age) }}
                    
                    {% set marital_status %}
                        <div class="flex items-center gap-2">
                            <span>{{ aboba.MarriedStatusString }}</span>
                            <img class="w-auto h-21 object-contain border-2 p-1 border-orange-400 rounded-xl" src="{{ asset( aboba.MarriedStatusFilename ) }}">
                        </div>
                    {% endset %}
                    {{ macros.info_row('Семейное положение', marital_status) }}
                    
                    {{ macros.info_row('Абоба создан', aboba.createdAt|ago(locale='ru')) }}
                </tbody>
            </table>
        </div>
        
        <a class="flex hover:bg-purple-900 items-center border-3 p-3 m-4 transition-all duration-300 hover:scale-105 gap-3 {{ container_classes }}"
           href="{{ path('app_home_page') }}">
            <img src="{{ asset('images/back_arrow.png') }}" class="w-12 h-12">
            <span class="text-yellow-300 text-4xl">Назад</span>
        </a>
    </div>
{% endblock %}
