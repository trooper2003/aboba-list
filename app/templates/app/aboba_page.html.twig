{% extends 'base.html.twig' %}

{% block title %} Абоба {{ id }} {% endblock %}

{% block body %}
    <div class="flex flex-col items-center min-h-screen px-4">
        <h1 class="text-orange-400 text-6xl pb-10 pt-3 font-bold">Абоба номер {{ id }}</h1>

        <div class="border-4 border-orange-500 rounded-3xl p-5 bg-purple-800/30 shadow-2xl">
            <table class="text-3xl text-yellow-300 border-separate border-spacing-x-6 border-spacing-y-4">
                <tbody>
                <tr class="border-b border-orange-500/30">
                    <th class="text-orange-400 text-right font-black uppercase tracking-wider">Имя:</th>
                    <td class="font-light">{{ aboba.name }}</td>
                </tr>
                <tr>
                    <th class="text-orange-400 text-right font-black uppercase tracking-wider">Возраст:</th>
                    <td class="font-light">{{ aboba.age }}</td>
                </tr>
                </tbody>
            </table>
        </div>
        <a class="flex hover:bg-purple-900 items-center border-3 border-orange-500 rounded-3xl p-3 m-4 bg-purple-800/30 shadow-2xl transition-all duration-300 hover:scale-105"
           href="{{ path('app_home_page') }}">

            <img src="{{ asset('images/back_arrow.png') }}"
            class="w-12 h-12">
            <span class="text-yellow-300 text-4xl">Назад</span>
        </a>
    </div>
{% endblock %}
