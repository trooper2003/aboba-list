<div class="relative group transition-all" data-controller="closeable">
    <a class="flex flex-col hover:bg-purple-900 items-center border-3 border-orange-500 rounded-3xl p-2 m-2 bg-purple-800/30 shadow-2xl transition-all duration-300 hover:scale-105 transition-all"
       href="{{ path('app_aboba_page', {aboba: obj.id }) }}">
        <span class="text-yellow-300 text-2xl">{{ obj.name }}</span>
    </a>
    <button type="button"
            class="absolute -top-1 -right-1 bg-red-600 hover:bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center border-2 border-orange-500 shadow-lg z-10 transition-transform hover:scale-110"
            data-action="closeable#close">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>
</div>
